# GitHub API 配置说明
#
# 用于技能商店集成 GitHub 数据（星标、下载量等）
# 可选配置，不配置时也可以使用（但会受到未认证速率限制：60 次/小时）

# GitHub Token（可选）
# 获取方式：https://github.com/settings/tokens
# 权限要求：public_repo (仅读取公开仓库信息)
#
# 注意：请勿将此文件提交到版本控制系统！
NEXT_PUBLIC_GITHUB_TOKEN=your_github_personal_access_token_here

# GitHub 组织名称（默认：procyc-skills）
NEXT_PUBLIC_GITHUB_OWNER=procyc-skills

# 缓存时间（毫秒，默认：300000 = 5 分钟）
NEXT_PUBLIC_GITHUB_CACHE_TTL=300000
