      "typeVersion": 1,
      "position": [650, 200],
      "credentials": {
        "smtp": "Your SMTP Credentials"
      }
    },
    {
      "parameters": {
        "fromEmail": "noreply@example.com",
        "toEmail": "={{$node['Webhook Trigger'].json[\"userId\"]}}",
        "subject": "❌ 很遗憾，您的门户申请未通过审核",
        "html": "=<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body { font-family: Arial, sans-serif; }\n    .container { max-width: 600px; margin: 0 auto; padding: 20px; }\n    .header { background: #f44336; color: white; padding: 20px; text-align: center; }\n    .content { padding: 20px; background: #f9f9f9; }\n    .reason { background: #fff3cd; padding: 15px; border-left: 4px solid #f44336; margin: 20px 0; }\n    .button { display: inline-block; padding: 10px 20px; background: #2196F3; color: white; text-decoration: none; border-radius: 5px; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h1>📋 审核结果通知</h1>\n    </div>\n    <div class=\"content\">\n      <h2>亲爱的 {{ $json.userName }}，</h2>\n      <p>感谢您提交门户申请。经过审核，我们很遗憾地通知您，您的申请暂未通过。</p>\n      <p><strong>门户名称：</strong>{{ $json.userName }}</p>\n      <div class=\"reason\">\n        <h3>审核意见：</h3>\n        <p>{{ $json.reason || '请参考平台规范进行修改后重新提交' }}</p>\n      </div>\n      <p>请您根据上述意见进行修改和完善后，重新提交申请。</p>\n      <p style=\"text-align: center; margin-top: 30px;\">\n        <a href=\"https://your-platform.com/portal/{{ $json.portalId }}/edit\" class=\"button\">修改我的门户</a>\n      </p>\n      <p style=\"margin-top: 30px; color: #666; font-size: 14px;\">\n        如有任何疑问，请联系我们的客服团队获取帮助。\n      </p>\n    </div>\n  </div>\n</body>\n</html>",
        "options": {}
      },
