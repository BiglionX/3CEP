        1050,
        450
      ]
    },
    {
      "parameters": {
        "keepOnlySet": true,
        "values": {
          "string": [
            {
              "name": "processId",
              "value": "={{ 'PS-' + Date.now() }}"
            },
            {
              "name": "orderId",
              "value": "={{ $json.order_id }}"
            },
            {
              "name": "status",
              "value": "completed"
            },
            {
              "name": "processedAt",
              "value": "={{ new Date().toISOString() }}"
            }
          ],
          "object": [
            {
              "name": "results",
              "value": {
                "notificationSent": "={{ $node['SendConfirmation'].json.success }}",
                "pointsUpdated": "={{ $node['UpdatePoints'].json.success }}",
                "logisticsStarted": "={{ $node['StartLogistics'].json.trackingNumber }}",
                "afterSalesSent": "={{ $node['SendAfterSales'].json.sent }}"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "ProcessAggregator",
      "name": "处理结果聚合",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [
        1250,
        300
      ]
    },
    {
      "parameters": {
        "functionCode": "// 错误处理和补偿机制\nconst originalData = $node['PaymentWebhook'].json;\nconst verificationResult = $node['SignatureValidator'].json;\nconst orderData = $node['OrderVerification'].json;\n\n// 检查各个步骤的执行结果\nconst stepResults = {\n  signatureValid: verificationResult.verified === true,\n  orderVerified: orderData && orderData.status === 'paid',\n  notificationSent: $node['SendConfirmation'].json && $node['SendConfirmation'].json.success,\n  pointsUpdated: $node['UpdatePoints'].json && $node['UpdatePoints'].json.success,\n  logisticsStarted: $node['StartLogistics'].json && $node['StartLogistics'].json.success,\n  afterSalesSent: $node['SendAfterSales'].json && $node['SendAfterSales'].json.success\n};\n\n// 如果有任何步骤失败，记录错误并尝试补偿\nif (Object.values(stepResults).some(result => result === false)) {\n  const failedSteps = Object.entries(stepResults)\n    .filter(([step, result]) => result === false)\n    .map(([step]) => step);\n  \n  console.error('Payment processing failed steps:', failedSteps);\n  \n  // 可以在这里添加补偿逻辑\n  // 例如：回滚积分更新、重新发送通知等\n  \n  return [{\n    json: {\n      success: false,\n      orderId: originalData.order_id,\n      failedSteps: failedSteps,\n      requiresManualIntervention: failedSteps.includes('orderVerified') || failedSteps.includes('signatureValid')\n    }\n  }];\n}\n\n// 所有步骤都成功\nreturn [{\n  json: {\n    success: true,\n    orderId: originalData.order_id,\n    processId: $node['ProcessAggregator'].json.processId,\n    results: stepResults\n  }\n}];"
      },
      "id": "ErrorHandler",
      "name": "错误处理器",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        1450,
        300
      ]
    }
