{
  "name": "支付成功后续处理工作流",
  "nodes": [
    {
      "parameters": {
        "path": "payment-success",
        "options": {},
        "responseMode": "lastNode"
      },
      "id": "PaymentWebhook",
      "name": "支付成功回调入口",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "functionCode": "// 验证支付回调签名\nconst crypto = require('crypto');\nconst secret = process.env.PAYMENT_WEBHOOK_SECRET || 'default_secret';\nconst payload = JSON.stringify($json);\nconst signature = $json.signature;\n\n// 简化的签名验证（实际应用中需要更复杂的算法）\nconst expectedSignature = crypto\n  .createHmac('sha256', secret)\n  .update(payload)\n  .digest('hex');\n\nif (signature !== expectedSignature) {\n  throw new Error('Invalid signature');\n}\n\n// 验证必需字段\nif (!$json.order_id || !$json.payment_id || !$json.amount) {\n  throw new Error('Missing required fields');\n}\n\nreturn [{\n  json: {\n    ...$json,\n    verified: true,\n    validation_time: new Date().toISOString()\n  }\n}];"
      },
      "id": "SignatureValidator",
      "name": "签名验证器",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "requestMethod": "GET",
        "url": "={{ $env.ORDER_SERVICE_API_URL || 'http://localhost:3000/api/orders' }}/{{ $json.order_id }}",
        "authentication": "none",
        "headers": {
          "Content-Type": "application/json"
        },
        "options": {}
      },
      "id": "OrderVerification",
      "name": "订单信息验证",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        650,
        250
      ]
    },
    {
      "parameters": {
        "requestMethod": "POST",
        "url": "={{ $env.NOTIFICATION_API_URL || 'http://localhost:3000/api/notifications/send' }}",
        "authentication": "none",
        "headers": {
          "Content-Type": "application/json"
        },
        "bodyParametersUi": {
          "parameter": [
            {
              "name": "userId",
              "value": "={{ $node['OrderVerification'].json.userId }}"
            },
            {
              "name": "type",
              "value": "order_confirmation"
            },
            {
              "name": "title",
              "value": "订单支付成功确认"
            },
            {
              "name": "content",
              "value": "={{ '您的订单 ' + $json.order_id + ' 已支付成功，金额 ¥' + $json.amount }}"
            },
            {
              "name": "channels",
              "value": "[\"in_app\", \"email\"]"
            }
          ]
        },
        "options": {}
      },
      "id": "SendConfirmation",
      "name": "发送确认通知",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        850,
        150
      ]
    },
    {
      "parameters": {
        "functionCode": "// 计算积分奖励\nconst orderAmount = $json.amount;\nconst baseRate = parseFloat(process.env.POINTS_CALCULATION_RATE || '0.1');\nconst vipLevel = $node['OrderVerification'].json.userVipLevel || 0;\nconst isFirstOrder = $node['OrderVerification'].json.isFirstOrder || false;\n\n// 基础积分\nlet points = Math.floor(orderAmount * baseRate);\n\n// VIP加成\nconst vipMultiplier = 1 + (vipLevel * 0.1);\npoints = Math.floor(points * vipMultiplier);\n\n// 首单奖励\nif (isFirstOrder) {\n  points += 100;\n}\n\n// 活动期间额外奖励\nconst currentDate = new Date();\nconst isPromotionPeriod = currentDate.getMonth() === 1; // 2月份\nif (isPromotionPeriod) {\n  points = Math.floor(points * 1.5);\n}\n\nreturn [{\n  json: {\n    userId: $node['OrderVerification'].json.userId,\n    orderId: $json.order_id,\n    pointsToAdd: points,\n    calculationDetails: {\n      basePoints: Math.floor(orderAmount * baseRate),\n      vipBonus: points - Math.floor(orderAmount * baseRate * vipMultiplier) + Math.floor(orderAmount * baseRate),\n      firstOrderBonus: isFirstOrder ? 100 : 0,\n      promotionBonus: isPromotionPeriod ? Math.floor(points / 3) : 0\n    }\n  }\n}];"
      },
      "id": "PointsCalculator",
      "name": "积分计算器",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        850,
        300
      ]
    },
    {
      "parameters": {
        "requestMethod": "POST",
        "url": "={{ $env.POINTS_API_URL || 'http://localhost:3000/api/user-points/update' }}",
        "authentication": "none",
