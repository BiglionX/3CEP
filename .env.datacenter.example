# 数据中心环境变量配置

# Trino查询引擎配置
TRINO_HOST=localhost
TRINO_PORT=8080
TRINO_COORDINATOR_URL=http://localhost:8080

# Redis缓存配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Lionfix数据库配置
LIONFIX_DB_HOST=localhost
LIONFIX_DB_PORT=5432
LIONFIX_DB_NAME=lionfix_db
LIONFIX_DB_USER=lionfix_reader
LIONFIX_DB_PASSWORD=your_lionfix_password

# Supabase/FixCycle数据库配置
SUPABASE_DB_HOST=localhost
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=fixcycle_db
SUPABASE_DB_USER=supabase_user
SUPABASE_DB_PASSWORD=your_supabase_password

# 数据中心API配置
DATA_CENTER_API_KEY=your_api_key_here
DATA_CENTER_CACHE_TTL=300