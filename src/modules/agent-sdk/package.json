{
  "name": "@fixcycle/agent-sdk",
  "version": "1.0.0",
  "type": "module",
  "description": "FixCycle 智能体开发工具包 - Agent SDK for FixCycle Marketplace",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fixcycle-agent": "./bin/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
