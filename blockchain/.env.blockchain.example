# Besu 私有链生产环境配置
# 复制此文件为 .env.blockchain 并根据实际情况修改

# ========================================
# 区块链网络配置
# ========================================

# Besu RPC 节点地址（主节点）
NEXT_PUBLIC_BLOCKCHAIN_RPC_URL=http://localhost:8545

# Chain ID (必须与 genesis.json 中的 chainId 一致)
NEXT_PUBLIC_BLOCKCHAIN_CHAIN_ID=2024

# 区块浏览器 URL（可选）
NEXT_PUBLIC_BLOCKCHAIN_EXPLORER_URL=

# ========================================
# 智能合约地址
# 部署后从 deployment-info.json 获取并更新此处
# ========================================

# ProductAuth 防伪溯源合约地址
NEXT_PUBLIC_PRODUCT_AUTH_CONTRACT=

# ========================================
# 运营商私钥（用于服务器端交易签名）
# 重要：请妥善保管，不要提交到版本控制！
# ========================================

# 运营商账户私钥（从创世块预分配账户中选择一个）
BLOCKCHAIN_PRIVATE_KEY=

# 运营商账户地址（对应私钥的地址）
BLOCKCHAIN_OPERATOR_ADDRESS=

# ========================================
# Gas 配置
# ========================================

# Gas 价格（Wei 单位，Besu 私有链通常设为 0）
BLOCKCHAIN_GAS_PRICE=0

# Gas 限制（每笔交易的最大 Gas）
BLOCKCHAIN_GAS_LIMIT=8000000

# ========================================
# 高级配置（可选）
# ========================================

# WebSocket RPC URL
BLOCKCHAIN_WS_URL=ws://localhost:8546

# 交易确认等待时间（秒）
BLOCKCHAIN_CONFIRMATIONS=1

# 请求超时时间（毫秒）
BLOCKCHAIN_TIMEOUT=30000

# 重试次数
BLOCKCHAIN_MAX_RETRIES=3
