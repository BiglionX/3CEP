MARKETING_UTM_TRACKING_ENABLED=true
MARKETING_DEMO_RATE_LIMIT=10
MARKETING_DEMO_TIME_WINDOW_HOURS=1

# 性能监控配置
PERFORMANCE_MONITORING_ENABLED=true
PERFORMANCE_METRICS_BATCH_SIZE=50
PERFORMANCE_DATA_RETENTION_DAYS=30

# SEO 配置
NEXT_PUBLIC_DEFAULT_SEO_TITLE=FixCycle - 企业自动化解决方案
NEXT_PUBLIC_DEFAULT_SEO_DESCRIPTION=一站式n8n + 智能体企业自动化平台，提升工作效率，降低运营成本
