# 安全配置
MARKETING_API_RATE_LIMIT=100
MARKETING_IP_BLACKLIST=
MARKETING_USER_AGENT_WHITELIST=

# 开发调试配置
MARKETING_DEBUG_LOGGING=true
MARKETING_DEMO_MODE=true
NEXT_PUBLIC_SHOW_TEST_PAGES=true

# 邮件配置
MARKETING_NOTIFICATION_EMAIL=admin@fixcycle.com
MARKETING_SUPPORT_EMAIL=support@fixcycle.com

# 分析配置
MARKETING_ANALYTICS_ENABLED=true
MARKETING_EVENT_BUFFER_SIZE=100
MARKETING_TRACKING_COOKIE_NAME=fixcycle_marketing_session

# 数据库连接（直接连接）
