# 营销页面系统环境变量配置
# 复制此文件为 .env.local 并填入实际值

# ==================== 基础配置 ====================
NEXT_PUBLIC_SITE_URL=http://localhost:3006
NEXT_PUBLIC_APP_NAME=FixCycle
NEXT_PUBLIC_MARKETING_ENABLED=true
NODE_ENV=development

# ==================== Supabase 配置 ====================
NEXT_PUBLIC_SUPABASE_URL=https://hrjqzbhqueleszkvnsen.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_5e-tqlrRNyKW3fAmWJipIQ_1-fjS711
SUPABASE_SERVICE_ROLE_KEY=your_actual_service_role_key_here

# ==================== n8n 集成配置 ====================
N8N_API_URL=http://localhost:5678
N8N_API_TOKEN=your_actual_n8n_api_token_here
N8N_WEBHOOK_SECRET=your_secure_webhook_secret_here
N8N_LEAD_WEBHOOK_URL=http://localhost:5678/webhook/lead-capture
N8N_DEMO_WEBHOOK_URL=http://localhost:5678/webhook/demo-request
N8N_CONTACT_WEBHOOK_URL=http://localhost:5678/webhook/contact-form
N8N_HEALTH_CHECK_URL=http://localhost:5678/healthz
NEXT_PUBLIC_N8N_URL=https://n8n.yourdomain.com

# ==================== 营销功能配置 ====================
MARKETING_LEAD_DUPLICATION_CHECK=true
MARKETING_SESSION_TIMEOUT_MINUTES=30
MARKETING_UTM_TRACKING_ENABLED=true
MARKETING_DEMO_RATE_LIMIT=5
MARKETING_DEMO_TIME_WINDOW_HOURS=1

# ==================== 性能监控配置 ====================
PERFORMANCE_MONITORING_ENABLED=true
PERFORMANCE_METRICS_BATCH_SIZE=50
PERFORMANCE_DATA_RETENTION_DAYS=30

# ==================== SEO 配置 ====================
NEXT_PUBLIC_DEFAULT_SEO_TITLE=FixCycle - 企业自动化解决方案
NEXT_PUBLIC_DEFAULT_SEO_DESCRIPTION=一站式n8n + 智能体企业自动化平台
NEXT_PUBLIC_DEFAULT_SEO_KEYWORDS=企业自动化,n8n,工作流,智能体,RPA

# ==================== 安全配置 ====================
MARKETING_API_RATE_LIMIT=100
MARKETING_IP_BLACKLIST=
MARKETING_USER_AGENT_WHITELIST=

# ==================== 开发调试配置 ====================
MARKETING_DEBUG_LOGGING=false
MARKETING_DEMO_MODE=false
NEXT_PUBLIC_SHOW_TEST_PAGES=true

# ==================== 邮件配置 ====================
MARKETING_NOTIFICATION_EMAIL=admin@fixcycle.com
MARKETING_SUPPORT_EMAIL=support@fixcycle.com

# ==================== 分析配置 ====================
MARKETING_ANALYTICS_ENABLED=true
MARKETING_EVENT_BUFFER_SIZE=100
MARKETING_TRACKING_COOKIE_NAME=fixcycle_marketing_session

# 注意事项:
# 1. 将此文件复制为 .env.local
# 2. 替换所有 your_actual_* 和 your_secure_* 为真实值
# 3. 生产环境中应使用更严格的配置
# 4. 敏感信息不应提交到版本控制系统